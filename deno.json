{
  "tasks": {
    "start": "deno run -A vite",
    "build": "deno run -A vite build",
    "preview": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "wasmbuild": "cd rs_lib && wasm-pack build --target web --out-dir ../static/wasm"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 80,
    "indentWidth": 4,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve",
    "exclude": ["generated", "node_modules", ".*"]
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*", "components/ui"],
  "imports": {
    "$std/": "https://deno.land/std@0.216.0/",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@radix-ui/react-slot": "npm:@radix-ui/react-slot@^1.2.4",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@iconify/react": "https://esm.sh/@iconify/react@4.0.0",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "clsx": "npm:clsx@^2.1.1",
    "daisyui": "npm:daisyui@^4.12.24",
    "dotenv": "npm:dotenv@^16.6.1",
    "framer-motion": "npm:framer-motion@^11.18.2",
    "lucide-preact": "npm:lucide-preact@^0.453.0",
    "preact": "npm:preact@^10.27.2",
    "react": "npm:@preact/compat@18.3.1",
    "react-dom": "npm:@preact/compat@18.3.1",
    "react-mobile-app-button": "npm:react-mobile-app-button@^1.2.19",
    "tailwind-merge": "npm:tailwind-merge@^2.6.0",
    "tailwindcss": "npm:tailwindcss@3.4.1",
    "tailwindcss-animate": "npm:tailwindcss-animate@^1.0.7",
    "tailwindcss/": "npm:/tailwindcss@3.4.1/",
    "tailwindcss/plugin": "npm:/tailwindcss@3.4.1/plugin.js",
    "vite": "npm:vite@^7.3.1",
    "~/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "fresh-i18n": "jsr:@elsoul/fresh-i18n@^1.2.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "nodeModulesDir": "auto",
  "deploy": {
    "project": "02d1034b-faed-4eb9-b436-d9b02655537a",
    "exclude": ["**/node_modules"],
    "include": ["./static", "./static/wasm"],
    "entrypoint": "main.ts"
  }
}
