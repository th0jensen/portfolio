{
  "name": "backend",
  "sourceRoot": "backend/src",
  "targets": {
    "build": {
      "dependsOn": ["frontend:build"],
      "command": "SKIP_BUN_BUILD=1 cargo build --release",
      "options": { "cwd": "backend" }
    },
    "dev": {
      "continuous": true,
      "command": "RUST_LOG=DEBUG cargo run",
      "options": { "cwd": "backend" }
    },
    "lint": {
      "dependsOn": ["frontend:build"],
      "command": "SKIP_BUN_BUILD=1 cargo clippy -- -D warnings",
      "options": { "cwd": "backend" }
    }
  }
}
