{
  "name": "frontend",
  "sourceRoot": "frontend/src",
  "targets": {
    "build": {
      "command": "bunx vite build",
      "options": { "cwd": "frontend" }
    },
    "lint": {
      "command": "bunx biome check .",
      "options": { "cwd": "frontend" }
    },
    "install": {
      "command": "bun install",
      "options": { "cwd": "frontend" }
    }
  }
}
